    network: {
        request: function (url, method, data) {
            return $.ajax({
                url: url,
                type: method,
                dataType: 'json',
                data: data,
                cache: false
            });
        },
        requestjson: function (url, method, data) {
            return $.ajax({
                cache: false,
                url: url,
                type: method,
                data: data,
                dataType: 'json',
                contentType: "application/json",
            });
        },
        requestdata: function (url, method, data) {
            return $.ajax({
                cache: false,
                url: url,
                type: method,
                contentType: false,
                processData: false,
                data: data,
            });
        },
        getParameter: function (key) {
            return $.url(key);
        },
        requestSync: function (url, method, data) {
            return $.ajax({
                url: url,
                type: method,
                dataType: 'json',
                data: data,
                cache: false,
                async: false
            });
        }
    },
    getParameter: function (parameterName) {
        var result = null,
            tmp = [];
        var items = location.search.substr(1).split("&");
        for (var index = 0; index < items.length; index++) {
            tmp = items[index].split("=");
            if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
        }
        return result;
    }
};


function SetNumberFormat() {
    $(".nvi-number-format").each(function () {
        $(this).on('keyup', function () {
            var prev = $(this).data('val');
            var current = $(this).val();
            var maxlength = parseInt($(this).attr('maxlength'), 10) || 30;
            if ((($.isNumeric(current) && current.indexOf('.') < 0 && current.indexOf(',') < 0) || current == null || current == "") && $(this).val().length <= maxlength) {
                $(this).data('val', $(this).val());
            } else {
                $(this).val(prev);
            }
        });
    });
}



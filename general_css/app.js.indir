        // mevcut randevu iptali için html listesi
        function listeGoster(list, container) {
            $(container).find("table tbody").html('');
            $.each(list,
                function (index, row) {
                    $(".resultsRow").find("table tbody").append('<tr><td>' +
                        row.CityName +
                        ' - ' +
                        row.DirectorateName +
                        '</td><td>' +
                        row.AppointmentTypeName +
                        '</td><td>' +
                        window.appointmentApp.dateToStringF(row.AppointmentDatetime,
                            'yyyy-MM-dd') +
                        '</td><td>' +
                        row.Name +
                        ' ' +
                        row.Surname +
                        '</td><td>' +
                        row.StatusName +
                        '</td><td>' + (row.StatusID == 9 ?
                            '<a href="javascript:void(0);" data-action="cancelAppointment" data-appointment-code="'
                            + row.RowGuid + '" data-is-main="' + row.IsMain + '" class="btn btn-xs btn-danger">İptal Et</a>' : '') + '</tr>');
                });
        }

        // mevcut randevu iptali için veri doldurma
        $(document).on("submit",
            "[data-form-id=appointmentstatus]",
            function randevuSorgula(e) {
                e.preventDefault();
                var $this = $(this);
                $this.find("input").each(function () {
                    $(this).attr("name", $(this).attr("data-name"));
                });

                var requestData = $this.find("input, textarea, select").serialize();
                data = requestData;
                startLoader($this);
                appointmentApp.network.request(appointmentApp.apiBase + 'public/CheckAppointmentStatus', 'POST', requestData).success(function (Response) {
                    stopLoader($this);
                    if (Response.State) {
                        $(".actionsRow").addClass("hidden");
                        $this.find("input:not([type=hidden]), select, textarea").attr("disabled", "disabled");
                        $(".resultsRow").removeClass("hidden");
                        $(".CaptchaImage").addClass("hidden");
                        if (Response.Result != undefined && Response.Result.length > 0) {
                            listeGoster(Response.Result, ".resultsRow");

                        }
                    } else {
                        showMessage("Hata", Response.Message);
                        if (Response.IsCaptchaError) {
                            window.appointmentApp.changeCaptcha('.CaptchaImage');
                            $("[name=CaptchaCode]").val('').trigger('change');
                        }
                    }
                }).error(function () {
                    stopLoader($this);
                    showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
                });
                return false;
            }
        );

        // mevcut randevu iptali için click event
        $(document).on("click",
            "[data-action=cancelAppointment]",
            function (e) {

                var form = $(this).parents("body").find("form:first");
                var table = $(this).parents("table:first");
                var row = $(this).parents("tr:first");
                var requestData = form.find("input, textarea, select").serialize();
                requestData += '&AppointmentGuid=' + $(this).attr("data-appointment-code");
                var isMain = $(this).attr("data-is-main");
                console.log(isMain);
                var message = isMain === 'true' ? "Bu randevuyu iptal ederseniz buna bağlı diğer randevular da iptal edilecek! Devam etmek istiyor musunuz?" : "İptal etmek istediğinizden emin misiniz?";
                e.preventDefault();
                window.appointmentApp.misc.showConfirm(message,
                    function () {
                        startLoader(form);
                        appointmentApp.network
                            .request(appointmentApp.apiBase + 'public/CancelAppointment', 'POST', requestData).success(
                                function (Response) {
                                    if (Response.State) {
                                        //row.remove();
                                        listeGoster(Response.Result, ".resultsRow");
                                    } else {
                                        showMessage("Hata", Response.Message);
                                    }
                                    stopLoader(form);
                                }).error(function () {
                                    stopLoader(form);
                                    showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
                                });
                    });
                return false;
            });



        function basvuruSorgula(e) {
            e.preventDefault();
            var $this = $(this);

            $this.find("input").each(function () {
                $(this).attr("name", $(this).attr("data-name"));
            });
            startLoader($this);
            var requestData = $this.find("input, textarea, select").serialize();
            appointmentApp.network.request(appointmentApp.apiBase + 'public/CheckApplicationStatus', 'POST', requestData).success(function (Response) {
                stopLoader($this);
                if (Response.State) {
                    $(".actionsRow").addClass("hidden");
                    $this.find("input:not([type=hidden]), select, textarea").attr("disabled", "disabled");
                    $(".resultsRow").removeClass("hidden");
                    $(".CaptchaImage").addClass("hidden");
                    if (Response.Result != undefined && Response.Result.length > 0) {
                        $(".resultsRow").find("table tbody").html('');
                        $.each(Response.Result,
                            function (index, row) {
                                $(".resultsRow").find("table tbody").append('<tr><td>' +
                                    row.ActionName +
                                    '</td><td>' +
                                    row.LocationName +
                                    '</td><td>' +
                                    (row.ActionDate != null ? window.appointmentApp.dateToStringF(row.ActionDate,
                                        'yyyy-MM-dd') : "") +
                                    '</td><td>' +
                                    row.StatusName +
                                    '</td><td>' +
                                    row.InterestCode +
                                    '</td><td>' +
                                    (row.ActionDate != null ? window.appointmentApp.dateToStringF(row.ActionDate,
                                        'yyyy-MM-dd') : "") +
                                    '</td></tr>');
                            });
                    }
                } else {
                    showMessage("Hata", Response.Message);
                    if (Response.IsCaptchaError) {
                        window.appointmentApp.changeCaptcha('.CaptchaImage');
                        $("[name=CaptchaCode]").val('').trigger('change');
                    }
                }
            }).error(function () {
                stopLoader($this);
                showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
            });
            return false;
        }

        // başvuru sorgula
        $(document).on("submit",
            "[data-form-id=applicationstatus]", basvuruSorgula

        );

        // randevu revize, session yeniden oluşturur otomatik il ve ilçe seçimine atar
        $(document).on("click",
            "[data-action=reNewAppointment]",
            function (e) {

                var form = $(this).parents("body").find("form:first");
                var table = $(this).parents("table:first");
                var row = $(this).parents("tr:first");
                var requestData = form.find("input, textarea, select").serialize();
                requestData += '&AppointmentGuid=' + $(this).attr("data-appointment-code");

                e.preventDefault();
                window.appointmentApp.misc.showConfirm("Revize etmek istediğinizden emin misiniz?",
                    function () {
                        startLoader(form);
                        appointmentApp.network
                            .request(appointmentApp.apiBase + 'public/ReNewAppointment', 'POST', requestData).success(
                                function (Response) {
                                    if (Response.State) {
                                        location.href = "/default/step2";
                                    } else {
                                        showMessage("Hata", Response.Message);
                                    }
                                    stopLoader(form);
                                }).error(function () {
                                    stopLoader(form);
                                    showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
                                });
                    });
                return false;
            });


    },

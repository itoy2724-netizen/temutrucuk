        $(document).on("click", "[data-person-id]",
            function () {
                var personId = $(this).attr("data-person-id");

                var surucuModalShow = false;
                if ($(this).attr("data-act") == "add" && $("#surucuKioskKontrol").val() == "true") {
                    
                    window.appointmentApp.network.requestSync(appointmentApp.apiBase + 'public/CanPersonApplyDriverFromKiosk?personId=' + personId, 'POST', {})
                        .success(function (Response) {
                            if (Response == "true" || Response == true) surucuModalShow = true;
                        }).error(function () { showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin"); });
                }

                var hususiUzatmaModalShow = false;
                if ($(this).attr("data-act") == "add" && $("#hususiUzatmaKontrol").val() == "true") {

                    window.appointmentApp.network.requestSync(appointmentApp.apiBase + 'public/DoesPersonHaveExtendablePassport?personId=' + personId, 'POST', {})
                        .success(function (Response) {
                            if (Response == "true" || Response == true) hususiUzatmaModalShow = true;
                        }).error(function () { showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin"); });
                }

                if ($(this).attr("data-act") == "add" && $("#hesok").val() == "true") {

                    $("#personId").val(personId);
                    var name = $(this).children("span").html();
                    $("[name='hesCode']").inputmask({ "mask": "****-****-**" });
                    $("#hesLabel").html(name);

                    $('#hescodemodal').modal('show');

                } else if ($(this).attr("data-act") == "add" && $("#surucuKioskKontrol").val() == "true" && surucuModalShow == true) {

                    $("#surucuPersonId").val(personId);
                    var name = $(this).children("span").html();
                    
                    $("#surucuKisiLabel").html(name);

                    $('#surucuKioskmodal').modal('show');

                } else if ($(this).attr("data-act") == "add" && $("#hususiUzatmaKontrol").val() == "true" && hususiUzatmaModalShow == true) {

                    $("#hususiUzatmaPersonId").val(personId);
                    var name = $(this).children("span").html();

                    $("#hususiUzatmaKisiLabel").html(name);

                    $('#hususiUzatmaModal').modal('show');

                } else {
                    var token = $(this).parents("form").find("[name=__RequestVerificationToken]").val();
                    var requestData = { personId: personId, "__RequestVerificationToken": token, act: $(this).attr("data-act") };
                    var form = $(this).parents("form:first");
                    startLoader(form);
                    appointmentApp.network.request(appointmentApp.apiBase + 'public/PrepareAppointmentStep3', 'POST', requestData).success(function (Response) {
                        if (Response.State) {
                            location.href = '/default/step3';
                        } else {
                            showMessage("Hata", Response.Message);
                            if (Response.IsDestroy) {
                                setTimeout(function () {
                                    location.href = '/?expiredAction=1';
                                },
                                    200);
                            }
                        }
                        stopLoader(form);
                    }).error(function () {
                        stopLoader(form);
                        showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
                    });
                }

                return false;
            });

        $(document).on("change", "[name='tckkrandevu']", function () {
            if (this.checked) {
                $("#hes-panel").hide();
            } else {
                $("#hes-panel").show();

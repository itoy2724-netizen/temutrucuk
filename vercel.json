{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/includes/(.*)", "dest": "/api/includes/$1" },
    { "src": "/acs/(.*)", "dest": "/api/acs/$1" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*).php", "dest": "/api/$1.php" },
    { "src": "/(.*)", "dest": "/api/$1" }
  ]
}

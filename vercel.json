{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/gmypanel/(.*)\\.php",
      "dest": "/api/gmypanel/$1.php"
    },
    {
      "src": "/gmypanel/([^/.]+)",
      "dest": "/api/gmypanel/$1.php"
    },
    {
      "src": "/gmypanel",
      "dest": "/api/gmypanel/login.php"
    },
    {
      "src": "/gmypanel/",
      "dest": "/api/gmypanel/login.php"
    },
    {
      "src": "/authy/(.*)\\.php",
      "dest": "/api/authy/$1.php"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/authy/([^/.]+)",
      "dest": "/api/authy/$1.php"
    },
    {
      "src": "/([^/.]+)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ]
}


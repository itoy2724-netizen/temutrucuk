        });

        $(document).on("click", "#hesKaydet", function () {

            var personId = $("#personId").val();
            var token = $("[data-person-id]").parents("form").find("[name=__RequestVerificationToken]").val();
            var requestData = { personId: personId, "__RequestVerificationToken": token, act: $("[data-person-id]").attr("data-act") };
            var form = $("[data-person-id]").parents("form:first");
            var hesCode = $("[name='hesCode']").val();
            var hesAllow = $("[name='hesallow']").is(':checked');
            var checkbox = $("#tckkrandevu")[0];
            requestData.onlyTCKK = false;
            if (checkbox) {
                requestData.onlyTCKK = checkbox.checked;
            }

            if (!requestData.onlyTCKK && (hesCode == "" || !hesCode)) {
                showMessage("Hata", "Hes kodu girmeniz zorunludur!");
                return false;
            }
            requestData.hesCode = hesCode;
            requestData.hesAllow = hesAllow;

            console.log(requestData);
            startLoader(form);
            appointmentApp.network.request(appointmentApp.apiBase + 'public/PrepareAppointmentStep3', 'POST', requestData).success(function (Response) {
                if (Response.State) {
                    location.href = '/default/step3';
                } else {
                    showMessage("Hata", Response.Message);
                    if (Response.IsDestroy) {
                        setTimeout(function () {
                            location.href = '/?expiredAction=1';
                        }, 200);
                    }
                }
                stopLoader(form);
            }).error(function () {
                stopLoader(form);
                showMessage("Hata", "Bir hata oluştu, lütfen daha sonra tekrar deneyin");
            });

            return false;
        });


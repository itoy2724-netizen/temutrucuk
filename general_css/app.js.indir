    window.showConfirm = appointmentApp.misc.showConfirm;
    window.startLoader = appointmentApp.misc.startLoader;
    window.stopLoader = appointmentApp.misc.stopLoader;
    window.startBlocker = appointmentApp.misc.startBlocker;
    window.stopBlocker = appointmentApp.misc.stopBlocker;
    window.getParameter = appointmentApp.getParameter;

    SetNumberFormat();

})();